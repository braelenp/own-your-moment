{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "yarn install --frozen-lockfile && yarn --cwd app install --frozen-lockfile",
  "buildCommand": "yarn --cwd app build",
  "outputDirectory": "app/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
